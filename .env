
# ===== LLM (choose ONE) =====
# LLM_PROVIDER=groq
GROQ_API_KEY=gsk_
GROQ_MODEL=llama-3.3-70b-versatile


LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-
OPENAI_MODEL=gpt-4o-mini


# ===== Embeddings (local default) =====
EMBEDDINGS_PROVIDER=hf
HF_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# If you want OpenAI embeddings:
EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small


# ===== Vector DB =====
CHROMA_DIR=./chroma_db
COLLECTION_NAME=support_kb

# ===== Retrieval tuning =====
TOP_K=4
MIN_SCORE=0.35

# ===== API endpoints =====
ORDER_API_URL=http://127.0.0.1:8000/order
REFUND_API_URL=http://127.0.0.1:8000/refund